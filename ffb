#!/usr/bin/env python3
"""Simple CLI wrapper for FancyFang Bot.

Usage: ./ffb sim [options]
Delegates the `sim` subcommand to `core.sim_bot.main()`.
"""
import sys
import os

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: ffb <command> [args]")
        sys.exit(1)

    cmd = sys.argv[1]
    if cmd != "sim":
        print(f"Unknown command: {cmd}\nSupported: sim")
        sys.exit(2)

    # Drop the subcommand and delegate remaining args to core.sim_bot
    sys.argv = [sys.argv[0]] + sys.argv[2:]

    # Ensure project root is on sys.path so `core` package can be imported
    PROJ_ROOT = os.path.dirname(__file__)
    if PROJ_ROOT not in sys.path:
        sys.path.insert(0, PROJ_ROOT)

    try:
        from core import sim_bot
    except Exception as e:
        print(f"Failed to import sim_bot: {e}")
        raise

    sim_bot.main()
